generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core Models ────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  emailVerified  DateTime? @map("email_verified")
  name           String?
  hashedPassword String?  @map("hashed_password")
  image          String?
  plan           String   @default("starter") // starter | pro | agency
  credits        Int      @default(100)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  accounts     Account[]
  sessions     Session[]
  apiKeys      ApiKey[]
  generations  Generation[]
  usageRecords UsageRecord[]
  subscription Subscription?
  creditBalance CreditBalance?

  @@map("users")
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  name        String
  environment String    // live | test
  prefix      String    // pk_live_xxxx or pk_test_xxxx (first 12 chars)
  hashedKey   String    @unique @map("hashed_key")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  revoked     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([hashedKey])
  @@index([userId])
  @@map("api_keys")
}

model Generation {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  type           String    // image | video | copy
  status         String    @default("queued") // queued | processing | scoring | passed | failed | delivered
  prompt         String
  refinedPrompt  String?   @map("refined_prompt")
  resultUrl      String?   @map("result_url")
  resultContent  String?   @map("result_content") @db.Text
  score          Float?
  creditsConsumed Int      @default(0) @map("credits_consumed")
  durationMs     Int?      @map("duration_ms")
  errorMessage   String?   @map("error_message")
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scoringResult ScoringResult?

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("generations")
}

model ScoringResult {
  id             String   @id @default(cuid())
  generationId   String   @unique @map("generation_id")
  dimensions     Json     // Array of { dimension, score, reasoning }
  aggregateScore Float    @map("aggregate_score")
  passed         Boolean
  qualityTier    String   @map("quality_tier") // starter | pro | agency
  feedback       String   @db.Text
  scoredAt       DateTime @default(now()) @map("scored_at")

  generation Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@map("scoring_results")
}

model UsageRecord {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  generationId    String?  @map("generation_id")
  endpoint        String
  creditsConsumed Int      @map("credits_consumed")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([endpoint])
  @@map("usage_records")
}

// ─── Billing Models ─────────────────────────────────────────────────────────

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String    @unique @map("stripe_customer_id")
  stripeSubscriptionId String?   @unique @map("stripe_subscription_id")
  stripePriceId        String?   @map("stripe_price_id")
  status               String    @default("inactive") // active | past_due | canceled | inactive
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean   @default(false) @map("cancel_at_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model CreditBalance {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  imageCredits Int      @default(100) @map("image_credits")
  videoCredits Int      @default(10) @map("video_credits")
  copyCredits  Int      @default(500) @map("copy_credits")
  resetAt      DateTime @default(now()) @map("reset_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}
